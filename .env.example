# Porta interna padrao da imagem/container.
# No Compose, PORT e fixo em 3000 no service api.
PORT=3000

# Porta publicada no host pelo Docker Compose.
API_HOST_PORT=3000

# Oracle Database externo
ORACLE_USER=seu_usuario
ORACLE_PASSWORD=sua_senha
ORACLE_CONNECT_STRING=oracle.example.com:1521/ORCLPDB1

# Oracle Instant Client dentro do container.
# No Compose, este caminho Linux e fixo; editar .env nao altera o service sem mudar docker-compose.yml.
# O pacote release 26ai usa bibliotecas Instant Client 23.x neste caminho
ORACLE_CLIENT_LIB_DIR=/usr/lib/oracle/23/client64/lib

# Opcional: diretorio do container para tnsnames.ora, sqlnet.ora ou wallet.
# No Compose, este caminho Linux e fixo; editar .env nao altera o service sem mudar docker-compose.yml.
# Para tnsnames.ora, use o alias em ORACLE_CONNECT_STRING; para wallet, monte o diretorio completo de wallet/config como read-only.
TNS_ADMIN=/opt/oracle/network/admin
